import math

#A class to perform various basic mathematical operations
class BasicOperations:

    def __init__(self,a,b):
        self.a=a
        self.b=b
    
    #Method 1 : Perform addition, substraction and multiplication
    def operations(self):
        return {
            "Sum ": self.a+self.b,
            "Difference":self.a-self.b,
            "Multiplication":self.a*self.b
            }
    
    #Method 2 : Perform division, show quotient and remainder
    def division(self):
        return {
            "Quotient":self.a//self.b,
            "Remained":self.a%self.b
            }
    
    #Method 3 : Factorial of a given number
    def factorial(self):
        return math.factorial(int(self.a))
    
    #Method 4 : Find greater of the two numbers
    def greater_num(self):
        return max(self.a,self.b)

